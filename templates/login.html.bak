<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Connexion EPIE RH</title>
  <style>
    body { font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; background:#f3f4f6; margin:0; display:flex; align-items:center; justify-content:center; height:100vh; }
    .card { background:#fff; border-radius:12px; box-shadow:0 10px 35px rgba(15,23,42,.15); padding:24px 26px; width:320px; }
    .title { font-size:18px; font-weight:700; margin-bottom:4px; }
    .sub { font-size:13px; color:#6b7280; margin-bottom:20px; }
    .fg { margin-bottom:14px; }
    .fl { font-size:12px; color:#4b5563; margin-bottom:4px; display:block; }
    .fc { width:100%; border-radius:8px; border:1px solid #e5e7eb; padding:8px 10px; font-size:13px; }
    .btn { width:100%; border-radius:999px; background:#16a34a; color:#fff; border:none; padding:9px 0; font-size:14px; font-weight:600; cursor:pointer; margin-top:8px; }
    .btn:hover { background:#15803d; }
    .err { font-size:12px; color:#b91c1c; margin-top:6px; min-height:16px; }
  </style>
</head>
<body>
  <div class="card">
    <div class="title">Connexion</div>
    <div class="sub">EPIE Formation · Espace RH</div>
    <div class="fg">
      <label class="fl">Login</label>
      <input class="fc" id="lg" autocomplete="username">
    </div>
    <div class="fg">
      <label class="fl">Mot de passe</label>
      <input class="fc" id="pw" type="password" autocomplete="current-password">
    </div>
    <button class="btn" onclick="doLogin()">Se connecter</button>
    <div class="err" id="err"></div>
  </div>
  <script>
    async function doLogin() {
      const lg = document.getElementById("lg").value.trim();
      const pw = document.getElementById("pw").value;
      const err = document.getElementById("err");
      err.textContent = "";
      if (!lg || !pw) {
        err.textContent = "Login et mot de passe requis";
        return;
      }
      try {
        const r = await fetch("/api/login", {
          method:"POST",
          headers:{ "Content-Type":"application/json" },
          body: JSON.stringify({ login:lg, password:pw })
        });
        const data = await r.json();
        if (!r.ok) {
          err.textContent = data.error || "Erreur de connexion";
          return;
        }
        window.location.href = "/";
      } catch(e) {
        err.textContent = "Erreur réseau";
      }
    }
    document.addEventListener("keydown", e => {
      if (e.key === "Enter") doLogin();
    });
  </script>
</body>
</html>